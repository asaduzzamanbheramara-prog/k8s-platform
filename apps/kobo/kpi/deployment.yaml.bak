apiVersion: apps/v1
kind: Deployment
metadata:
  name: kpi
  namespace: kobo

spec:
  replicas: 1

  selector:
    matchLabels:
      app: kpi

  template:
    metadata:
      labels:
        app: kpi

    spec:
      terminationGracePeriodSeconds: 90

      initContainers:
        - name: init-dirs
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              mkdir -p /mnt/media
              mkdir -p /mnt/logs
              mkdir -p /srv/src/kpi/staticfiles
              chmod -R 777 /mnt/media
              chmod -R 777 /mnt/logs
              chmod -R 777 /srv/src/kpi/staticfiles

          volumeMounts:
            - name: kpi-media
              mountPath: /mnt/media
            - name: kpi-logs
              mountPath: /mnt/logs
            - name: kpi-static
              mountPath: /srv/src/kpi/staticfiles

      containers:
        - name: kpi
          image: kobotoolbox/kpi:2.026.12i
          imagePullPolicy: IfNotPresent

          workingDir: /srv/src/kpi

          ports:
            - containerPort: 8000

          env:
            - name: DJANGO_SETTINGS_MODULE
              value: kobo.settings.override

            - name: PYTHONPATH
              value: /srv/src

            - name: SECRET_KEY
              value: shopnoltd-production-secret

            # ✅ FIXED: TWO DATABASES (CRITICAL)
            - name: DATABASE_URL
              value: postgresql://kobo:change_me@kobo-postgres.kobo.svc.cluster.local:5432/kpi

            - name: KOBOCAT_DATABASE_URL
              value: postgresql://kobo:change_me@kobo-postgres.kobo.svc.cluster.local:5432/kobocat

            - name: REDIS_URL
              value: redis://redis.kobo.svc.cluster.local:6379/0

            - name: CACHE_URL
              value: redis://redis.kobo.svc.cluster.local:6379/0

            - name: CELERY_BROKER_URL
              value: redis://redis.kobo.svc.cluster.local:6379/1

            - name: MONGO_DB_URL
              value: mongodb://mongo.kobo.svc.cluster.local:27017/kobo

            - name: STATIC_URL
              value: /static/

            - name: STATIC_ROOT
              value: /srv/src/kpi/staticfiles

            - name: ALLOWED_HOSTS
              value: "*"

          command:
            - /bin/bash
            - -c
            - |
              set -e

              echo "=== KPI START FIXED MODE ==="

              cd /srv/src/kpi

              echo "Django system check..."
              python manage.py check || true

              echo "Running migrations..."
              python manage.py migrate --noinput

              echo "Collecting static..."
              python manage.py collectstatic --noinput --clear

              echo "Starting uWSGI..."
              exec uwsgi \
                --http 0.0.0.0:8000 \
                --module kobo.wsgi:application \
                --master \
                --processes 2 \
                --threads 2 \
                --enable-threads \
                --buffer-size 65535 \
                --harakiri 120 \
                --max-requests 1000 \
                --vacuum \
                --die-on-term

          volumeMounts:
            - name: kpi-media
              mountPath: /srv/src/kpi/media

            - name: kpi-logs
              mountPath: /srv/src/kpi/logs

            - name: kpi-static
              mountPath: /srv/src/kpi/staticfiles

            - name: kpi-settings
              mountPath: /srv/src/kpi/kobo/settings/override.py
              subPath: override.py

      volumes:
        - name: kpi-media
          persistentVolumeClaim:
            claimName: kpi-media-pvc

        - name: kpi-logs
          persistentVolumeClaim:
            claimName: kpi-logs-pvc

        - name: kpi-static
          emptyDir: {}

        - name: kpi-settings
          configMap:
            name: kpi-settings-override
